push {
  uvec2 _ScreenDims;
  vec2  _Pos;
  float _Radius;
};

out vec2 _UV;

void main() {
  const vec2 uvMap[6] = vec2[](
    vec2(-1.0, -1.0),
    vec2(-1.0, 1.0),
    vec2(1.0, 1.0),
    vec2(1.0, 1.0),
    vec2(1.0, -1.0),
    vec2(-1.0, -1.0)
  );

  const float ar = float(_ScreenDims.x) / float(_ScreenDims.y);

  vec2 uv = uvMap[gl_VertexIndex];
  vec2 worldPos = _Pos + uv * _Radius;
  vec2 clipPos = worldPos / vec2(ar, 1.0);

  gl_Position = vec4(clipPos, 0.0, 1.0);
  _UV = uv;
}
